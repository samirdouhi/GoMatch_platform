{
  "Jwt": {
    "Key": "",
    "Issuer": "GoMatch.AuthService",
    "Audience": "GoMatch.Users"
  },
  "Services": {
    "AuthService": "https://localhost:7007/",
    "ProfileService": "https://localhost:7114/"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/touriste/profile/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7007/"
          }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7114/"
          }
        }
      }
    }
  }
}