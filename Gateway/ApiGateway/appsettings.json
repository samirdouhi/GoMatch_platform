{
  "Jwt": {
    "Key": "",
    "Issuer": "GoMatch.AuthService",
    "Audience": "GoMatch.Users"
  },
  "Services": {
    "AuthService": "https://localhost:7007/",
    "ProfileService": "https://localhost:7114/",
    "BusinessService": "https://localhost:59006/"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "email-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/email/{**catch-all}"
        }
      },
      "touriste-profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/touriste/profile/{**catch-all}"
          }
        ]
      },
      "commercant-profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/commercant-profile/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/commercant/profile/{**catch-all}"
          }
        ]
      },
      "admin-profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/admin-profile/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/admin/profile/{**catch-all}"
          }
        ]
      },
      "business-route": {
        "ClusterId": "business-cluster",
        "Match": {
          "Path": "/business/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/business"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7007/"
          }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7114/"
          }
        }
      },
      "business-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:59006/"
          }
        }
      }
    }
  }
}